# --- Server ---
PRECURSOR_HOST=127.0.0.1
# Backend (FastAPI/uvicorn) port. In `--dev` you browse the Vite UI on :5173,
# which proxies /api here; in production FastAPI serves the SPA + API on this
# port, so you browse this one directly.
PRECURSOR_PORT=8000
PRECURSOR_LOG_LEVEL=info
# Comma-separated list of allowed CORS origins (only needed when frontend runs
# on a different origin, e.g. Vite dev server at http://localhost:5173).
PRECURSOR_CORS_ORIGINS=http://localhost:5173

# --- Database ---
# SQLite (dev default):
PRECURSOR_DATABASE_URL=sqlite+aiosqlite:///./precursor.db
# Postgres (prod) example:
# PRECURSOR_DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/precursor

# --- LLM provider ---
# The active provider (GitHub Copilot, GitHub Models, Azure AI Foundry, OpenAI,
# Mistral, Hugging Face, Ollama, or Mock) and its credentials are configured at
# runtime in the app — Settings → Model — not via the environment. The GitHub
# providers fall back to your `gh auth login` session when no token is saved.
