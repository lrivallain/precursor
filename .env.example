# --- Server ---
PRECURSOR_HOST=127.0.0.1
PRECURSOR_PORT=8000
PRECURSOR_LOG_LEVEL=info
# Comma-separated list of allowed CORS origins (only needed when frontend runs
# on a different origin, e.g. Vite dev server at http://localhost:5173).
PRECURSOR_CORS_ORIGINS=http://localhost:5173

# --- Database ---
# SQLite (dev default):
PRECURSOR_DATABASE_URL=sqlite+aiosqlite:///./precursor.db
# Postgres (prod) example:
# PRECURSOR_DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/precursor

# --- LLM provider ---
# Supported: github_copilot | github_models | mock  (default: github_copilot)
#   github_copilot — Copilot model catalogue (gho_* token from `gh auth login`)
#   github_models  — GitHub Models inference (PAT with `models:read`)
#   mock           — offline deterministic replies, no token needed
PRECURSOR_LLM_PROVIDER=github_copilot
# Token for github_copilot / github_models. Read from GITHUB_TOKEN (unprefixed)
# to match GitHub Actions and the `gh` CLI. Leave blank to fall back to the
# mock provider automatically.
GITHUB_TOKEN=
