# --- Server ---
PRECURSOR_HOST=127.0.0.1
PRECURSOR_PORT=8000
PRECURSOR_LOG_LEVEL=info
# Comma-separated list of allowed CORS origins (only needed when frontend runs
# on a different origin, e.g. Vite dev server at http://localhost:5173).
PRECURSOR_CORS_ORIGINS=http://localhost:5173

# --- Database ---
# SQLite (dev default):
PRECURSOR_DATABASE_URL=sqlite+aiosqlite:///./precursor.db
# Postgres (prod) example:
# PRECURSOR_DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/precursor

# --- LLM provider ---
# Supported: github_models | mock
PRECURSOR_LLM_PROVIDER=github_models
PRECURSOR_LLM_MODEL=openai/gpt-4o-mini
# GitHub Models uses a PAT with the "models:read" fine-grained permission
# (a classic GITHUB_TOKEN also works for hosted runners).
GITHUB_TOKEN=

# --- GitHub integration ---
# Default repo used as the topic reference (owner/name). Can be overridden in Settings.
PRECURSOR_GITHUB_REPO=
